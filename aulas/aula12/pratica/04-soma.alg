algoritmo "soma"
var
   x, y: real
procedimento soma()
inicio
      escreval("A soma de A e B ķ",x+y)
fimprocedimento
inicio
      escreva("Digite um n·mero:")
      leia(x)
      escreva("Digite outro n·mero:")
      leia(y)
      
      limpatela
      escreval("Valor A:",x)
      escreval("Valor B:",y)
      soma()
fimalgoritmo