algoritmo "soma_procedimento"
var
   num_1, num_2: inteiro
procedimento soma(a, b: inteiro)
inicio
      escreval("Valor de A:", a)
      escreval("Valor de B:", b)
      escreval("Soma entre A e B:", a + b)
fimprocedimento
inicio
      num_1 <- 5
      num_2 <- 3

      soma(num_1, num_2)
fimalgoritmo
