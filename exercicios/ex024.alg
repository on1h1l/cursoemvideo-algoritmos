algoritmo "ex024"
var
   distance, price: real
inicio
      escreva("Digite a dist‚ncia (km):")
      leia(distance)
      
      limpaTela
      se (distance <= 200) entao
         price <- 200*0.5
      senao
           price <- 200*0.45
      fimSe
      
      escrevaL("Dist‚ncia percorrida:",distance,"km")
      escrevaL("PreÁo da passagem: R$",price:5:2)
fimAlgoritmo