algoritmo "aumento_salarial_15_porcento"
var
   emp_sal, new_salary: real
inicio
      escreva("Sal·rio atual do funcion·rio: R$")
      leia(emp_sal)
      
      new_salary <- emp_sal*1.15
      
      limpaTela
      escrevaL("Sal·rio antigo: R$",emp_sal)
      escrevaL("Novo sal·rio: R$",new_salary)
fimAlgoritmo
