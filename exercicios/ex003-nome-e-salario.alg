algoritmo "nome_e_salario"
var
   emp_name: caractere
   emp_sal: real
inicio
      escreva("Nome do funcion·rio:")
      leia(emp_name)
      escreva("Sal·rio do funcion·rio: R$")
      leia(emp_sal)
      
      limpaTela
      escrevaL("O funcion·rio ",emp_name," recebeu R$",emp_sal," esse mÍs.")
fimAlgoritmo
