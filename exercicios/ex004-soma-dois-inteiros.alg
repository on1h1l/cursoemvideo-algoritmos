algoritmo "soma_dois_inteiros"
var
   num_1, num_2, total: inteiro
inicio
      escreva("Digite um numero inteiro:")
      leia(num_1)
      escreva("Digite outro numero inteiro:")
      leia(num_2)

      total <- num_1 + num_2

      limpatela
      escreval("A soma entre", num_1, " e", num_2, " e igual a", total)
fimalgoritmo
